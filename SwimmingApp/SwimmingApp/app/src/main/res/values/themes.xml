<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Tema base de la app compatible con Jetpack Compose.
        Se cambia el padre de Theme.MaterialComponents (Views) a Theme.Material3 (Compose).
        NoActionBar evita que aparezca la barra de título nativa de Android,
        ya que Compose gestiona su propia TopAppBar dentro del Scaffold.
    -->
    <style name="Theme.SwimmingApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Colores de marca -->
        <item name="colorPrimary">@color/azul_marino</item>
        <item name="colorOnPrimary">@color/blanco</item>
        <item name="colorSecondary">@color/amarillo</item>
        <item name="colorOnSecondary">@color/azul_marino</item>

        <!-- Fondo y superficies -->
        <item name="android:colorBackground">@color/bg_pantalla</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/texto_primario</item>

        <!-- Barra de estado del sistema (la de la hora/batería arriba) -->
        <item name="android:statusBarColor">@color/azul_marino</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>