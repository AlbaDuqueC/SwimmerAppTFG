<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_pantalla"
    android:orientation="vertical"
    android:padding="@dimen/espacio_l">

    <TextView
        style="@style/TextoTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/espacio_l"
        android:layout_marginBottom="@dimen/espacio_l"
        android:text="Perfil del usuario"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/espacio_l">

            <ImageView
                android:id="@+id/imgFotoPerfil"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_circle_avatar_grande"
                android:src="@drawable/usuario"
                android:padding="20dp"
                android:scaleType="fitCenter"
                app:tint="@color/blanco"
                android:contentDescription="Foto de perfil"
                android:layout_marginBottom="@dimen/espacio_m"/>

            <TextView
                android:id="@+id/tvNombreCompleto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Apellidos"
                android:textSize="@dimen/texto_xl"
                android:textStyle="bold"
                android:textColor="@color/texto_primario"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@ejemplo.com"
                android:textSize="@dimen/texto_s"
                android:textColor="@color/gris_texto"
                android:layout_marginTop="@dimen/espacio_xs"/>

            <TextView
                android:id="@+id/tvRol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nadador"
                android:textSize="@dimen/texto_s"
                android:textColor="@color/azul_marino"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/espacio_xs"/>

            <TextView
                android:id="@+id/tvEquipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equipo: -"
                android:textSize="@dimen/texto_s"
                android:textColor="@color/texto_primario"
                android:layout_marginTop="@dimen/espacio_xs"/>

            <Button
                android:id="@+id/btnEditarPerfil"
                style="@style/Boton.Primario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar perfil"
                android:layout_marginTop="@dimen/espacio_l"/>

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cerrar sesión"
                android:textAllCaps="false"
                android:textColor="@color/naranja"
                android:textStyle="bold"
                android:textSize="@dimen/texto_s"
                android:background="@android:color/transparent"
                android:layout_marginTop="@dimen/espacio_s"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>