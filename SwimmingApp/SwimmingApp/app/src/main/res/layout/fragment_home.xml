<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A8D8E8"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/imgPerfil"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Perfil"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Menú"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calendario semanal"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="7"
        android:layout_marginBottom="24dp">

        <TextView android:text="L" android:layout_width="0dp" android:layout_columnWeight="1" android:gravity="center"/>
        <TextView android:text="M" android:layout_width="0dp" android:layout_columnWeight="1" android:gravity="center"/>
        <TextView android:text="X" android:layout_width="0dp" android:layout_columnWeight="1" android:gravity="center"/>
        <TextView android:text="J" android:layout_width="0dp" android:layout_columnWeight="1" android:gravity="center"/>
        <TextView android:text="V" android:layout_width="0dp" android:layout_columnWeight="1" android:gravity="center"/>
        <TextView android:text="S" android:layout_width="0dp" android:layout_columnWeight="1" android:gravity="center"/>
        <TextView android:text="D" android:layout_width="0dp" android:layout_columnWeight="1" android:gravity="center"/>
    </GridLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Siguientes eventos"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEventos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
