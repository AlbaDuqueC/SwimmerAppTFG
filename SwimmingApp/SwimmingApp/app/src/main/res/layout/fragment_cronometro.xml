<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_pantalla"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/espacio_l">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/espacio_l">

            <TextView
                android:id="@+id/tvNadadorPrueba"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prueba"
                android:textSize="@dimen/texto_m"
                android:textColor="@color/texto_primario"
                android:layout_marginBottom="@dimen/espacio_l"/>

            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginBottom="@dimen/espacio_l"
                android:background="@drawable/bg_circulo_amarillo_grande">

                <TextView
                    android:id="@+id/tvTiempo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="00:00"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_primario"
                    android:fontFamily="monospace"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/espacio_l">

                <ImageButton
                    android:id="@+id/btnPlayStop"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@android:drawable/ic_media_play"
                    android:background="@drawable/bg_circle_naranja"
                    android:scaleType="center"
                    app:tint="@color/blanco"
                    android:layout_marginEnd="@dimen/espacio_l"/>

                <ImageButton
                    android:id="@+id/btnReset"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_stop_square"
                    android:background="@drawable/bg_square_naranja"
                    android:scaleType="center"
                    android:contentDescription="Reiniciar cronómetro"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnCrear"
                style="@style/Boton.Primario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>