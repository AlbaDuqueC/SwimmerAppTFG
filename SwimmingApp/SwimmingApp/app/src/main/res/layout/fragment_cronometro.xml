<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A8D8E8"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvNadadorPrueba"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nadador / 100m"
        android:textSize="14sp"
        android:textColor="#1A3A4A"
        android:layout_marginBottom="32dp"/>

    <!-- Círculo naranja con el tiempo -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="32dp">

        <!-- Fondo del círculo -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/circulo_naranja"/>

        <!-- TextView que muestra el tiempo con milisegundos -->
        <TextView
            android:id="@+id/tvTiempo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="00:00"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#1A3A4A"
            android:fontFamily="monospace"/>

    </FrameLayout>

    <!-- Botones play/stop y reset -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <ImageButton
            android:id="@+id/btnPlayStop"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_media_play"
            android:background="#F4A825"
            android:layout_marginEnd="24dp"/>

        <ImageButton
            android:id="@+id/btnReset"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="#1A3A4A"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnCrear"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Crear"
        android:backgroundTint="#F4A825"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="48dp"/>

</LinearLayout>