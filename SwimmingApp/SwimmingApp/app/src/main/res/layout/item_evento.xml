<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="@dimen/espacio_m"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_evento"
    android:layout_marginBottom="@dimen/espacio_s">

    <TextView
        android:id="@+id/tvLetraInicial"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_circle_amarillo"
        android:gravity="center"
        android:text="E"
        android:textColor="@color/blanco"
        android:textStyle="bold"
        android:layout_marginEnd="@dimen/espacio_m"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreEvento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrenamiento"
            android:textSize="@dimen/texto_s"
            android:textStyle="bold"
            android:textColor="@color/texto_primario"/>

        <TextView
            android:id="@+id/tvFechaEvento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:textSize="@dimen/texto_xs"
            android:textColor="@color/gris_texto"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnEditar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Editar nadador"
        android:src="@android:drawable/ic_menu_edit"
        android:visibility="gone"
        app:tint="#219EBC" />

    <ImageButton
        android:id="@+id/btnEliminar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Eliminar nadador"
        android:visibility="gone"/>

</LinearLayout>