<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_pantalla"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/espacio_m">

        <TextView
            android:id="@+id/tvHeaderMias"
            style="@style/TextoSeccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mis marcas"
            android:layout_marginBottom="@dimen/espacio_s"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMarcas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="@dimen/espacio_l"/>

        <TextView
            android:id="@+id/tvHeaderEntrenador"
            style="@style/TextoSeccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Asignadas por mi entrenador"
            android:layout_marginBottom="@dimen/espacio_s"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMarcasEntrenador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="@dimen/espacio_l"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAnadir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:contentDescription="Añadir marca"
            app:backgroundTint="@color/naranja"
            app:tint="@color/blanco"
            app:srcCompat="@android:drawable/ic_input_add"/>

    </LinearLayout>
</ScrollView>